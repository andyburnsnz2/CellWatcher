<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="CellWatcher" Manufacturer="CellWatcher" Version="1.0.0.0"
          UpgradeCode="8F3C2A5E-7D91-4A6B-9E2C-1B5F8A3D6C77">

    <!-- INSTALLMODE defaults to Service for a true one-click install; override for a silent/
         advanced install, e.g. CellWatcher-Setup.exe INSTALLMODE=Task -->
    <Variable Name="INSTALLMODE" Type="string" Value="Service" bal:Overridable="yes" />

    <!-- Fixed, not randomised per install - see the summary notes on this tradeoff. This local
         MariaDB instance only ever listens on localhost (never exposed through the firewall
         rules the MSI adds, which cover only the app's own web/MQTT ports), so the practical
         exposure is low, but a future improvement would generate these per-install instead. -->
    <Variable Name="MariaRootPassword" Type="string" Value="Bemu-2sFYJoqdBSc02fGvvX5b!" Hidden="yes" />
    <Variable Name="AppDbPassword" Type="string" Value="Bemu-UVlD6VRENm2nA4ZTsSZI!" Hidden="yes" />

    <BootstrapperApplication>
      <PayloadGroupRef Id="WixStandardBootstrapperApplication_X64" />
      <bal:WixStandardBootstrapperApplication LicenseFile="License.rtf" Theme="rtfLicense" />
    </BootstrapperApplication>

    <Chain>
      <MsiPackage Id="MariaDbPackage"
                  SourceFile="$(var.MariaDbCacheFile)"
                  DownloadUrl="https://downloads.mariadb.org/rest-api/mariadb/12.3.2/mariadb-12.3.2-winx64.msi"
                  Vital="yes">
        <MsiProperty Name="PASSWORD" Value="[MariaRootPassword]" />
        <MsiProperty Name="SERVICENAME" Value="MariaDB" />
        <MsiProperty Name="PORT" Value="3306" />
        <MsiProperty Name="ALLOWREMOTEROOTACCESS" Value="0" />
      </MsiPackage>

      <MsiPackage Id="CellWatcherMsiPackage"
                  SourceFile="$(var.CellWatcher.Setup.Msi.TargetPath)"
                  Vital="yes">
        <MsiProperty Name="INSTALLMODE" Value="[INSTALLMODE]" />
      </MsiPackage>

      <ExePackage Id="HelperPackage"
                  SourceFile="$(var.CellWatcher.Setup.Helper.TargetPath)"
                  Vital="yes"
                  PerMachine="yes"
                  Permanent="yes"
                  DetectCondition="0"
                  InstallArguments="--install-dir &quot;[ProgramFiles64Folder]CellWatcher&quot; --maria-root-password &quot;[MariaRootPassword]&quot; --app-db-password &quot;[AppDbPassword]&quot; --install-mode &quot;[INSTALLMODE]&quot;" />
    </Chain>

  </Bundle>
</Wix>
