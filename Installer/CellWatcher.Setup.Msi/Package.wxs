<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="CellWatcher" Manufacturer="CellWatcher" Version="1.0.0.0"
            UpgradeCode="122331FF-9D73-41DA-8086-F080C9C0D336" Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of CellWatcher is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Set by the Bundle, or overridable directly for a silent/advanced install, e.g.
         msiexec /i CellWatcher.Setup.msi INSTALLMODE=Task -->
    <Property Id="INSTALLMODE" Value="Service" Secure="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="CellWatcher" />
    </StandardDirectory>

    <!-- appsettings.json ships with the build-time default here (harvested along with everything
         else) and is then overwritten in place by CellWatcher.Setup.Helper, run as a later Bundle
         step once MariaDB and this MSI are both installed, since it needs the generated MariaDB
         credentials and whatever it discovers on the network. -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**" />
    </ComponentGroup>

    <!-- These components don't ship a file of their own — CellWatcher.exe is already installed by
         the glob-harvested AppFiles group above, and a second Component can't also claim it as a
         KeyPath (duplicate destination path). A registry value is the standard lightweight KeyPath
         for a Component that only carries behaviour (ServiceInstall/FirewallException), not content. -->
    <Component Id="ServiceComponent" Directory="INSTALLFOLDER" Guid="C1E5C9C0-9E9C-4E2E-8C8B-9C2A1F6E7B22" Condition="INSTALLMODE=&quot;Service&quot;">
      <RegistryValue Root="HKLM" Key="Software\CellWatcher" Name="InstallMode" Type="string" Value="Service" KeyPath="yes" />
      <ServiceInstall Id="CellWatcherServiceInstall"
                      Name="CellWatcher"
                      DisplayName="CellWatcher Monitor"
                      Description="Monitors and logs home battery telemetry over MQTT and serves the local dashboard."
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem" />
      <ServiceControl Id="CellWatcherServiceControl"
                       Name="CellWatcher"
                       Start="install"
                       Stop="both"
                       Remove="uninstall"
                       Wait="yes" />
      <!-- The app deliberately exits (non-zero) to apply a config change instead of respawning a
           detached process - see RestartAfterResponseFlushes in ApiEndpoints.cs - relying on this
           recovery config so SCM relaunches the same service image rather than us doing it by hand. -->
      <util:ServiceConfig ServiceName="CellWatcher"
                           FirstFailureActionType="restart"
                           SecondFailureActionType="restart"
                           ThirdFailureActionType="restart"
                           RestartServiceDelayInSeconds="5"
                           ResetPeriodInDays="1" />
    </Component>

    <!-- No Component needed here for Task mode itself — schtasks.exe registration is handled
         entirely by the CustomActions below, gated on the same INSTALLMODE property. -->

    <CustomAction Id="CreateScheduledTask"
                  Directory="INSTALLFOLDER"
                  ExeCommand="&quot;[SystemFolder]schtasks.exe&quot; /create /tn &quot;CellWatcher&quot; /tr &quot;\&quot;[INSTALLFOLDER]CellWatcher.exe\&quot;&quot; /sc onstart /ru SYSTEM /rl HIGHEST /f"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="RemoveScheduledTask"
                  Directory="INSTALLFOLDER"
                  ExeCommand="&quot;[SystemFolder]schtasks.exe&quot; /delete /tn &quot;CellWatcher&quot; /f"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="CreateScheduledTask" After="InstallFiles" Condition="INSTALLMODE=&quot;Task&quot; AND NOT Installed" />
      <Custom Action="RemoveScheduledTask" Before="RemoveFiles" Condition="INSTALLMODE=&quot;Task&quot; AND (Installed AND (NOT UPGRADINGPRODUCTCODE) AND REMOVE=&quot;ALL&quot;)" />
    </InstallExecuteSequence>

    <!-- Web dashboard port and the MQTT broker's own listen port (Standalone mode) - both need
         to accept inbound connections from other machines on the LAN (the browser, the emulator). -->
    <Component Id="FirewallComponent" Directory="INSTALLFOLDER" Guid="9E3D7B2A-6C4F-4A8E-B1D9-3E7C5A2F8B44">
      <RegistryValue Root="HKLM" Key="Software\CellWatcher" Name="FirewallRulesAdded" Type="integer" Value="1" KeyPath="yes" />
      <fw:FirewallException Id="WebDashboardFirewallRule"
                             Name="CellWatcher Web Dashboard"
                             Description="Allows access to the CellWatcher web dashboard"
                             Port="5000"
                             Protocol="tcp"
                             Scope="any" />
      <fw:FirewallException Id="MqttBrokerFirewallRule"
                             Name="CellWatcher MQTT Broker"
                             Description="Allows the battery emulator to publish to CellWatcher's local MQTT broker"
                             Port="1883"
                             Protocol="tcp"
                             Scope="any" />
    </Component>

    <Feature Id="MainFeature" Title="CellWatcher" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ServiceComponent" />
      <ComponentRef Id="FirewallComponent" />
    </Feature>

  </Package>
</Wix>
